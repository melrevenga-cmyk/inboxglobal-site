<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Outbound Domain Portfolio Planner — InboxGlobal™</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #050C17;
    --surface: #080F1C;
    --surface-2: #0C1628;
    --surface-3: #0f1e35;
    --border: rgba(34,211,238,0.12);
    --border-strong: rgba(34,211,238,0.25);
    --accent: #22D3EE;
    --accent-dim: rgba(34,211,238,0.08);
    --accent-mid: rgba(34,211,238,0.18);
    --text: #E2EBF3;
    --text-muted: #6B859E;
    --text-dim: #3A5068;
    --amber: #FBBF24;
    --red: #EF4444;
    --orange: #F97316;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(34,211,238,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(34,211,238,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  body::after {
    content: '';
    position: fixed;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(34,211,238,0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
    position: relative;
    z-index: 1;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    background: rgba(5,12,23,0.88);
    backdrop-filter: blur(12px);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--accent);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover, .nav-links a.active { color: var(--accent); }

  .nav-cta {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--bg) !important;
    background: var(--accent);
    padding: 8px 18px;
    text-decoration: none;
    border-radius: 4px;
    transition: opacity 0.2s;
  }

  .nav-cta:hover { opacity: 0.85; }

  /* ─── PAGE HEADER ─── */
  .page-header {
    padding: 140px 0 64px;
    position: relative;
    z-index: 1;
    border-bottom: 1px solid var(--border);
  }

  .hero-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #94A3B8;
    margin-bottom: 28px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 7px 18px;
    border-radius: 100px;
  }

  .hero-tag-dot {
    width: 7px; height: 7px;
    background: #22C55E;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .page-header h1 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(40px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 0.98;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .page-header h1 em {
    font-style: normal;
    background: linear-gradient(90deg, #22D3EE 0%, #67E8F9 60%, #A5F3FC 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-header p {
    font-size: 16px;
    font-weight: 400;
    color: var(--text-muted);
    max-width: 520px;
    line-height: 1.7;
  }

  /* ─── TOOL SECTION ─── */
  .tool-section {
    padding: 72px 0 100px;
    position: relative;
    z-index: 1;
  }

  .section-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 40px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .section-label.accent { color: var(--accent); }

  /* ─── PLANNER WRAP ─── */
  .planner-wrap {
    max-width: 720px;
    margin: 0 auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .planner-inner {
    padding: 48px 52px 56px;
  }

  /* ─── FORM ELEMENTS ─── */
  .field-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .field-hint {
    font-size: 12px;
    color: var(--text-dim);
    margin-top: 6px;
  }

  .field-err {
    font-size: 11px;
    color: var(--red);
    margin-top: 4px;
    display: none;
  }

  .field-inp {
    width: 100%;
    background: var(--surface-2);
    border: 1px solid rgba(34,211,238,0.1);
    border-radius: 4px;
    padding: 12px 16px;
    font-size: 16px;
    font-family: 'DM Sans', sans-serif;
    color: var(--text);
    outline: none;
    -moz-appearance: textfield;
    transition: border-color 0.2s;
  }

  input[type=number]::-webkit-inner-spin-button,
  input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; }

  .field-inp:focus { border-color: var(--accent); }
  .field-inp.error { border-color: var(--red); }

  .g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; }

  /* ─── TIMELINE BUTTONS ─── */
  .tl-group { margin-top: 24px; }

  .tl-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 10px;
  }

  .tl-btn {
    flex: 1;
    min-width: 64px;
    padding: 10px 6px;
    border-radius: 4px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: pointer;
    background: var(--surface-2);
    border: 1px solid rgba(34,211,238,0.1);
    color: var(--text-muted);
    text-align: center;
    user-select: none;
    transition: all 0.15s;
  }

  .tl-btn:hover { border-color: rgba(34,211,238,0.3); color: var(--text); }
  .tl-btn.active { background: var(--accent-dim); border-color: var(--accent); color: var(--accent); }

  /* ─── STANDARDS BOX ─── */
  .standards-box {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px 24px;
    margin-top: 24px;
  }

  .standards-head {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 14px;
  }

  .std-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px 0; }

  .std-row {
    display: flex;
    gap: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.5;
  }

  .std-dash { color: var(--accent); flex-shrink: 0; }

  /* ─── GENERATE BUTTON ─── */
  .gen-btn {
    width: 100%;
    border-radius: 4px;
    padding: 15px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    margin-top: 24px;
    text-align: center;
    user-select: none;
    background: var(--surface-2);
    color: var(--text-dim);
    border: 1px solid var(--border);
    transition: all 0.2s;
  }

  .gen-btn.ready {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  .gen-btn.ready:hover { opacity: 0.88; }

  /* ─── RESULTS ─── */
  .back-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    cursor: pointer;
    margin-bottom: 28px;
    display: inline-block;
    user-select: none;
    transition: color 0.2s;
  }

  .back-btn:hover { color: var(--accent); }

  .integrity-banner {
    border-radius: 4px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .banner-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .banner-val {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .banner-right {
    text-align: right;
  }

  .banner-standard {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .banner-flags {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 4px;
  }

  /* ─── SECTION HEADS ─── */
  .result-sec { margin-bottom: 24px; }

  .result-head {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  /* ─── METRIC GRID ─── */
  .mg { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

  .mc {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 16px 18px;
  }

  .mc.hi { border-color: var(--border-strong); }

  .mc-l {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 6px;
  }

  .mc-v {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 28px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }

  .mc-s { font-size: 12px; color: var(--text-dim); }

  /* ─── COST BOX ─── */
  .cost-box {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px 24px;
    margin-bottom: 24px;
  }

  .cg { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-top: 14px; }

  .cc {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px 16px;
  }

  .cc-l {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 6px;
  }

  .cc-v {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }

  .cc-s { font-size: 11px; color: var(--text-dim); }

  .cost-footnote {
    margin-top: 12px;
    font-size: 11px;
    color: var(--text-dim);
  }

  /* ─── RISK FLAGS ─── */
  .risk-item {
    border-radius: 4px;
    padding: 12px 16px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
    margin-bottom: 6px;
  }

  .risk-lvl {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    flex-shrink: 0;
    min-width: 54px;
  }

  .risk-msg { font-size: 13px; color: #b8c4e0; line-height: 1.5; }

  /* ─── NOTE BLOCKS ─── */
  .nb {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }

  .nr {
    display: flex;
    gap: 12px;
    padding: 13px 18px;
    align-items: flex-start;
  }

  .nr + .nr { border-top: 1px solid var(--border); }

  .na {
    color: var(--accent);
    font-weight: 700;
    flex-shrink: 0;
    font-size: 14px;
    margin-top: 1px;
  }

  .nt {
    font-size: 13px;
    color: #8898c0;
    line-height: 1.6;
    font-family: 'DM Sans', sans-serif;
  }

  /* ─── WARMUP TABLE ─── */
  .wt {
    display: grid;
    grid-template-columns: 72px 100px 60px 1fr;
    gap: 8px;
    align-items: center;
    padding: 10px 18px;
  }

  .wt + .wt { border-top: 1px solid var(--border); }

  /* ─── TOOL ITEMS ─── */
  .tool-item {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 16px 18px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
    margin-bottom: 6px;
    transition: border-color 0.2s;
  }

  .tool-item:hover { border-color: var(--border-strong); }

  .ti-icon {
    font-size: 18px;
    width: 36px;
    height: 36px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ti-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 2px 8px;
    border-radius: 3px;
    margin-left: 8px;
  }

  .ti-cat {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .ti-name {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    margin: 4px 0 2px;
    color: var(--text);
  }

  .ti-alt {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: var(--text-muted);
    margin-left: 6px;
  }

  .ti-why { font-size: 12px; color: var(--text-dim); line-height: 1.5; }

  /* ─── LEGEND ─── */
  .leg-row {
    display: flex;
    gap: 16px;
    padding: 12px 18px;
    align-items: flex-start;
  }

  .leg-row + .leg-row { border-top: 1px solid var(--border); }

  .leg-s {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 700;
    min-width: 64px;
    flex-shrink: 0;
  }

  .leg-d { font-size: 13px; color: #8898c0; line-height: 1.5; }

  /* ─── INLINE CTA ─── */
  .inline-cta {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px 24px;
    text-align: center;
    margin-bottom: 24px;
  }

  .inline-cta p {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .inline-cta a {
    color: var(--accent);
    font-size: 14px;
    font-weight: 700;
    font-family: 'DM Sans', sans-serif;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .inline-cta a:hover { opacity: 0.8; }

  /* ─── PLANNER FOOTER ─── */
  .planner-footer {
    display: flex;
    justify-content: space-between;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    color: var(--text-dim);
    padding-top: 16px;
    border-top: 1px solid var(--border);
    margin-top: 8px;
  }

  /* ─── BACK TO RESOURCES ─── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 32px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover { color: var(--accent); }

  .breadcrumb span { color: var(--text-dim); }

  .breadcrumb .current { color: var(--text-muted); }

  /* ─── SITE FOOTER ─── */
  footer {
    border-top: 1px solid var(--border);
    padding: 40px 0;
    position: relative;
    z-index: 1;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-logo {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 15px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--accent);
    text-decoration: none;
  }

  .footer-links {
    display: flex;
    gap: 24px;
    list-style: none;
  }

  .footer-links a {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--accent); }

  .footer-copy {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: var(--text-dim);
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .page-header .hero-tag { animation: fadeUp 0.5s ease both; }
  .page-header h1 { animation: fadeUp 0.5s 0.08s ease both; }
  .page-header p { animation: fadeUp 0.5s 0.16s ease both; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .planner-inner { padding: 28px 24px 36px; }
    .g2, .mg, .cg { grid-template-columns: 1fr; }
    .std-grid { grid-template-columns: 1fr; }
    .wt { grid-template-columns: 64px 88px 52px 1fr; gap: 4px; }
    .coming-grid { grid-template-columns: 1fr; }
    .tl-btn { min-width: 52px; font-size: 11px; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="https://inboxglobal.io" class="nav-logo">InboxGlobal™</a>
    <ul class="nav-links">
      <li><a href="https://inboxglobal.io#offers">Services</a></li>
      <li><a href="https://inboxglobal.io#principles">Principles</a></li>
      <li><a href="https://inboxglobal.io#founder">About</a></li>
      <li><a href="https://inboxglobal.io/resources" class="active">Resources</a></li>
      <li><a href="https://inboxglobal.io#cta" class="nav-cta">Book a Call</a></li>
    </ul>
  </div>
</nav>

<!-- PAGE HEADER -->
<section class="page-header">
  <div class="container">
    <div class="hero-tag">
      <span class="hero-tag-dot"></span>
      Interactive Tool · Free to use
    </div>
    <h1>Outbound Domain<br><em>Portfolio Planner</em></h1>
    <p>Input your sending volume, timeline, and existing infrastructure — get a structured domain plan with separation logic, cost breakdown, and risk flags. Built on InboxGlobal audit standards.</p>
  </div>
</section>

<!-- TOOL SECTION -->
<section class="tool-section">
  <div class="container">

    <div class="section-label accent">Infrastructure Calculator · InboxGlobal Standard</div>

    <div class="planner-wrap">
      <div class="planner-inner">

        <!-- BREADCRUMB -->
        <div class="breadcrumb">
          <a href="https://inboxglobal.io/resources">← Resources</a>
          <span>/</span>
          <span class="current">Domain Planner</span>
        </div>

        <!-- FORM VIEW -->
        <div id="form-view">
          <div>
            <div class="field-label">Target Daily Send Volume</div>
            <input class="field-inp" id="vol" type="number" min="0" placeholder="e.g. 500"/>
            <div class="field-err" id="err-vol">Required</div>
            <div class="field-hint">Total outbound emails per day across all domains</div>
          </div>

          <div class="g2">
            <div>
              <div class="field-label">Aged Domains On Hand</div>
              <input class="field-inp" id="aged" type="number" min="0" placeholder="e.g. 5"/>
              <div class="field-err" id="err-aged">Required</div>
              <div class="field-hint">90+ days · .com or .net · 40 sends/mb/day</div>
            </div>
            <div>
              <div class="field-label">New Domains On Hand</div>
              <input class="field-inp" id="newD" type="number" min="0" placeholder="e.g. 0"/>
              <div class="field-err" id="err-newD">Required</div>
              <div class="field-hint">Under 90 days · starts at 5 sends/mb/day</div>
            </div>
          </div>

          <div class="tl-group">
            <div class="field-label">Launch Timeline</div>
            <div class="tl-row" id="tl-row">
              <div class="tl-btn active" data-val="immediate">Immediate</div>
              <div class="tl-btn" data-val="15">15 Days</div>
              <div class="tl-btn" data-val="30">30 Days</div>
              <div class="tl-btn" data-val="60">60 Days</div>
              <div class="tl-btn" data-val="90plus">90+ Days</div>
            </div>
          </div>

          <div class="standards-box">
            <div class="standards-head">// Applied Standards</div>
            <div class="std-grid">
              <div class="std-row"><span class="std-dash">—</span><span>.com primary · .net acceptable</span></div>
              <div class="std-row"><span class="std-dash">—</span><span>Aged: 5 mailboxes · 40 sends/mb/day</span></div>
              <div class="std-row"><span class="std-dash">—</span><span>New: 3 mailboxes · step ramp over 30 days</span></div>
              <div class="std-row"><span class="std-dash">—</span><span>Extra domains planned at full rate</span></div>
              <div class="std-row"><span class="std-dash">—</span><span>20% buffer headroom built in</span></div>
              <div class="std-row"><span class="std-dash">—</span><span>Root domain only — no subdomains</span></div>
            </div>
          </div>

          <div class="gen-btn" id="gen-btn">Generate Plan →</div>
        </div>

        <!-- RESULTS VIEW -->
        <div id="results-view" style="display:none">
          <div class="back-btn" id="back-btn">← Recalculate</div>

          <div class="integrity-banner" id="banner">
            <div>
              <div class="banner-label">System Integrity Assessment</div>
              <div class="banner-val" id="b-val"></div>
            </div>
            <div class="banner-right">
              <div class="banner-standard">InboxGlobal Standard</div>
              <div class="banner-flags" id="b-flags"></div>
            </div>
          </div>

          <div class="result-sec">
            <div class="result-head">Infrastructure Plan</div>
            <div class="mg" id="mg"></div>
          </div>

          <div class="cost-box">
            <div class="result-head" style="border-bottom:none;margin-bottom:0;padding-bottom:0;">Estimated Monthly Cost</div>
            <div class="cg" id="cg"></div>
            <div class="cost-footnote">* Domains + mailboxes only. Platform and monitoring not included.</div>
          </div>

          <div class="result-sec" id="risks-sec" style="display:none">
            <div class="result-head">Risk Flags</div>
            <div id="risks-list"></div>
          </div>

          <div class="result-sec">
            <div class="result-head">Operator Notes</div>
            <div class="nb" id="notes"></div>
          </div>

          <div class="result-sec">
            <div class="result-head">Warmup Schedule</div>
            <div class="nb" id="warmup"></div>
            <div class="field-hint" style="margin-top:8px">Per new mailbox · Step up only when bounce &lt; 2% and spam &lt; 0.08%</div>
          </div>

          <div class="result-sec">
            <div class="result-head">Recommended Tool Stack</div>
            <div id="tools"></div>
          </div>

          <div class="result-sec">
            <div class="result-head">Integrity Legend</div>
            <div class="nb" id="legend"></div>
          </div>

          <div class="inline-cta">
            <p>Need help implementing this plan?</p>
            <a href="mailto:hello@inboxglobal.io">hello@inboxglobal.io · Book a 15-min call</a>
          </div>

          <div class="planner-footer">
            <span>inboxglobal.io · © 2026 InboxGlobal™ LLC</span>
            <span>Diagnostic output · Not a guarantee</span>
          </div>
        </div>

      </div><!-- /planner-inner -->
    </div><!-- /planner-wrap -->

  </div>
</section>

<!-- SITE FOOTER -->
<footer>
  <div class="footer-inner">
    <a href="https://inboxglobal.io" class="footer-logo">InboxGlobal™</a>
    <div class="footer-copy">© 2026 InboxGlobal™ LLC. All rights reserved.</div>
  </div>
</footer>

<script>
window.addEventListener("load", function() {

  var TL = "immediate";
  var SENDS_MAX=40, MB_AGED=5, MB_NEW=3, BUFFER=0.20, DOM_YR=14, MB_MO=3.50;
  var RAMP = {immediate:0,"15":15,"30":30,"60":60,"90plus":90};

  var iMap = {
    "Solid":    {color:"#22D3EE",bg:"rgba(34,211,238,0.08)",border:"rgba(34,211,238,0.25)"},
    "Review":   {color:"#FBBF24",bg:"rgba(251,191,36,0.08)",border:"rgba(251,191,36,0.25)"},
    "At Risk":  {color:"#F97316",bg:"rgba(249,115,22,0.08)",border:"rgba(249,115,22,0.25)"},
    "Critical": {color:"#EF4444",bg:"rgba(239,68,68,0.08)",border:"rgba(239,68,68,0.25)"}
  };

  var lMap = {
    "Critical": {color:"#EF4444",bg:"rgba(239,68,68,0.08)",border:"rgba(239,68,68,0.25)"},
    "High":     {color:"#F97316",bg:"rgba(249,115,22,0.08)",border:"rgba(249,115,22,0.25)"},
    "Medium":   {color:"#FBBF24",bg:"rgba(251,191,36,0.08)",border:"rgba(251,191,36,0.25)"}
  };

  var TOOLS = [
    {cat:"Mailboxes",     icon:"✉",  name:"Zapmail",     alt:"",        why:"Dedicated sending inboxes with built-in warmup tracking.",                                              tag:"Primary"},
    {cat:"Domain Reg.",   icon:"🌐", name:"Zapmail",     alt:"GoDaddy", why:"Integrated domain + mailbox provisioning. GoDaddy for bulk .com at scale.",                           tag:"Primary"},
    {cat:"Monitoring",    icon:"📡", name:"EmailGuard",  alt:"GlockApps",why:"Inbox placement testing, blacklist monitoring, reputation signals.",                                  tag:"Required"},
    {cat:"Outreach",      icon:"⚡", name:"Instantly",   alt:"Smartlead",why:"Sequence management, inbox rotation, and per-domain sending limits.",                                tag:"Primary"}
  ];

  var LEGEND = [
    {s:"Solid",    c:"#22D3EE", d:"Architecturally sound. No structural risks identified."},
    {s:"Review",   c:"#FBBF24", d:"Minor risks present. Monitor closely during ramp."},
    {s:"At Risk",  c:"#F97316", d:"High-severity issues. Adjust plan before launch."},
    {s:"Critical", c:"#EF4444", d:"Structural failures. Do not scale without remediation."}
  ];

  var WARMUP = [
    {phase:"Phase 1", days:"Days 1–7",   sends:5,  note:"Establish pattern. Monitor complaints closely."},
    {phase:"Phase 2", days:"Days 8–14",  sends:10, note:"Step up only if signals are healthy."},
    {phase:"Phase 3", days:"Days 15–21", sends:20, note:"Mid-ramp. Watch inbox placement daily."},
    {phase:"Phase 4", days:"Days 22–30", sends:30, note:"Near full capacity. Vary templates."},
    {phase:"Full",    days:"Day 31+",    sends:40, note:"Full rate. Maintain monitoring cadence."}
  ];

  function effSends(d) {
    if(d>=31) return 40;
    if(d>=22) return 30;
    if(d>=15) return 20;
    if(d>=8)  return 10;
    return 5;
  }

  // Timeline buttons
  var tlBtns = document.querySelectorAll(".tl-btn");
  for(var i=0; i<tlBtns.length; i++) {
    tlBtns[i].addEventListener("click", function() {
      for(var j=0; j<tlBtns.length; j++) tlBtns[j].classList.remove("active");
      this.classList.add("active");
      TL = this.getAttribute("data-val");
    });
  }

  // Volume input → enable button
  document.getElementById("vol").addEventListener("input", function() {
    var btn = document.getElementById("gen-btn");
    if(this.value !== "") btn.classList.add("ready");
    else btn.classList.remove("ready");
  });

  // Generate
  document.getElementById("gen-btn").addEventListener("click", function() {
    var ok = true;
    var ids = ["vol","aged","newD"];
    for(var i=0; i<ids.length; i++) {
      var el = document.getElementById(ids[i]);
      var er = document.getElementById("err-"+ids[i]);
      if(el.value === "") { el.classList.add("error"); er.style.display="block"; ok=false; }
      else { el.classList.remove("error"); er.style.display="none"; }
    }
    if(!ok) return;

    var vol  = parseInt(document.getElementById("vol").value)  || 0;
    var aged = parseInt(document.getElementById("aged").value) || 0;
    var newD = parseInt(document.getElementById("newD").value) || 0;
    if(vol <= 0) return;

    var days    = RAMP[TL] || 0;
    var snEff   = effSends(days);
    var capAged = aged * MB_AGED * SENDS_MAX;
    var capNewEff = newD * MB_NEW * snEff;
    var shortfall = Math.max(0, vol - capAged - capNewEff);
    var extra = shortfall > 0 ? Math.ceil(shortfall / (MB_NEW * SENDS_MAX)) : 0;
    var tA=aged, tN=newD+extra, tD=tA+tN, tMB=tA*MB_AGED+tN*MB_NEW;
    var effCap  = tA*MB_AGED*SENDS_MAX + tN*MB_NEW*snEff;
    var fullCap = tA*MB_AGED*SENDS_MAX + tN*MB_NEW*SENDS_MAX;
    var buf=Math.ceil(tD*BUFFER), rec=tD+buf;
    var domCost=(rec*DOM_YR)/12, mbCost=tMB*MB_MO, total=domCost+mbCost;

    // Risk assessment
    var risks = [];
    if(TL==="immediate" && tN>0) risks.push({level:"Critical",msg:"New domains start at 5 sends/mb/day. Effective capacity is lower until warmup completes."});
    if(aged===0 && newD===0)     risks.push({level:"Critical",msg:"No existing infrastructure. Full volume unreachable immediately."});
    if(aged===0)                 risks.push({level:"High",    msg:"No aged domains. All capacity relies on new domains with ramp constraints."});
    if(effCap>0 && vol/effCap>0.85) risks.push({level:"Medium",msg:"Effective capacity above 85%. No headroom for spikes during ramp."});
    if(extra>0) risks.push({level:"Medium",msg:extra+" additional new domain"+(extra>1?"s":"")+" required beyond current inventory."});

    // Integrity score
    var integrity = "Solid";
    for(var r=0; r<risks.length; r++) { if(risks[r].level==="Critical") { integrity="Critical"; break; } }
    if(integrity==="Solid") for(var r=0; r<risks.length; r++) { if(risks[r].level==="High") { integrity="At Risk"; break; } }
    if(integrity==="Solid") for(var r=0; r<risks.length; r++) { if(risks[r].level==="Medium") { integrity="Review"; break; } }

    // Banner
    var m = iMap[integrity];
    var bn = document.getElementById("banner");
    bn.style.background = m.bg;
    bn.style.border = "1px solid "+m.border;
    document.getElementById("b-val").style.color = m.color;
    document.getElementById("b-val").textContent = integrity;
    document.getElementById("b-flags").textContent = risks.length===0 ? "No flags raised" : risks.length+" flag"+(risks.length>1?"s":"")+" raised";

    // Metrics
    var mgHTML = "";
    var mets = [
      {v:tD,                       l:"Total Domains",       s:tA+" aged · "+tN+" new",                          hi:false},
      {v:rec,                      l:"Recommended Total",   s:"Incl. +"+buf+" buffer domains",                  hi:true},
      {v:tMB,                      l:"Total Mailboxes",     s:(tA*MB_AGED)+" aged · "+(tN*MB_NEW)+" new",       hi:false},
      {v:effCap.toLocaleString(),  l:"Effective Capacity",  s:"New @ "+snEff+" sends/mb/day",                   hi:false},
      {v:fullCap.toLocaleString(), l:"Full Capacity",       s:"After warmup (all @ 40/mb/day)",                 hi:false},
      {v:extra>0?"+"+extra:"None", l:"Extra Domains Needed",s:"Beyond current inventory",                       hi:extra>0}
    ];
    for(var i=0; i<mets.length; i++) {
      var x=mets[i];
      mgHTML += '<div class="mc'+(x.hi?" hi":"")+'"><div class="mc-l">'+x.l+'</div><div class="mc-v" style="color:'+(x.hi?"#22D3EE":"#E2EBF3")+'">'+x.v+'</div><div class="mc-s">'+x.s+'</div></div>';
    }
    document.getElementById("mg").innerHTML = mgHTML;

    // Costs
    var cgHTML = "";
    var costs = [
      {l:"Domain Registration",    v:"$"+domCost.toFixed(0)+"/mo", s:rec+" domains @ $"+DOM_YR+"/yr",     hi:false},
      {l:"Mailbox Infrastructure", v:"$"+mbCost.toFixed(0)+"/mo",  s:tMB+" mailboxes @ $"+MB_MO+"/mo",   hi:false},
      {l:"Total Infra",            v:"$"+total.toFixed(0)+"/mo",   s:"Domains + mailboxes only",          hi:true}
    ];
    for(var i=0; i<costs.length; i++) {
      var c=costs[i];
      cgHTML += '<div class="cc"><div class="cc-l">'+c.l+'</div><div class="cc-v" style="color:'+(c.hi?"#22D3EE":"#E2EBF3")+'">'+c.v+'</div><div class="cc-s">'+c.s+'</div></div>';
    }
    document.getElementById("cg").innerHTML = cgHTML;

    // Risks
    var rs = document.getElementById("risks-sec");
    if(risks.length > 0) {
      rs.style.display = "block";
      var rHTML = "";
      for(var i=0; i<risks.length; i++) {
        var lm = lMap[risks[i].level];
        rHTML += '<div class="risk-item" style="background:'+lm.bg+';border:1px solid '+lm.border+'"><span class="risk-lvl" style="color:'+lm.color+'">'+risks[i].level+'</span><span class="risk-msg">'+risks[i].msg+'</span></div>';
      }
      document.getElementById("risks-list").innerHTML = rHTML;
    } else {
      rs.style.display = "none";
    }

    // Notes
    var notes = [];
    if(TL==="immediate" && tN>0) notes.push("New domains start at 5 sends/mb/day. Do not push volume before reputation signals confirm stability.");
    if(tN>0) notes.push("Ramp: 5 → 10 → 20 → 30 → 40 sends/mb/day. Step up only when signals are healthy.");
    notes.push(extra>0 ? "Register "+extra+" additional .com domain"+(extra>1?"s":"")+" to meet target volume." : "Current inventory covers target volume.");
    notes.push("Buffer domains: authenticated but inactive. Rotate in only on cooldown or incident.");
    notes.push("No subdomains. All sending from root domain level.");
    var nHTML = "";
    for(var i=0; i<notes.length; i++) nHTML += '<div class="nr"><span class="na">→</span><span class="nt">'+notes[i]+'</span></div>';
    document.getElementById("notes").innerHTML = nHTML;

    // Warmup
    var wHTML = "";
    for(var i=0; i<WARMUP.length; i++) {
      var w=WARMUP[i], active=w.sends===snEff;
      var c=active?"#22D3EE":"#6B859E", bg=active?"rgba(34,211,238,0.06)":"transparent";
      wHTML += '<div class="wt" style="background:'+bg+'">'
        +'<span style="font-size:10px;font-weight:700;font-family:\'DM Sans\',sans-serif;color:'+c+';text-transform:uppercase;letter-spacing:.08em">'+w.phase+'</span>'
        +'<span style="font-size:12px;color:'+c+'">'+w.days+'</span>'
        +'<span style="font-family:\'Plus Jakarta Sans\',sans-serif;font-size:15px;font-weight:800;color:'+c+'">'+w.sends+'/day</span>'
        +'<span style="font-size:12px;color:#3A5068;line-height:1.5">'+w.note+'</span>'
        +'</div>';
    }
    document.getElementById("warmup").innerHTML = wHTML;

    // Tools
    var tHTML = "";
    for(var i=0; i<TOOLS.length; i++) {
      var t=TOOLS[i];
      tHTML += '<div class="tool-item">'
        +'<div class="ti-icon">'+t.icon+'</div>'
        +'<div style="flex:1">'
        +'<div style="display:flex;align-items:center;gap:4px;margin-bottom:4px"><span class="ti-cat">'+t.cat+'</span><span class="ti-tag">'+t.tag+'</span></div>'
        +'<div class="ti-name">'+t.name+(t.alt?'<span class="ti-alt">/ '+t.alt+'</span>':"")+'</div>'
        +'<div class="ti-why">'+t.why+'</div>'
        +'</div></div>';
    }
    document.getElementById("tools").innerHTML = tHTML;

    // Legend
    var lHTML = "";
    for(var i=0; i<LEGEND.length; i++) {
      var l=LEGEND[i];
      lHTML += '<div class="leg-row"><span class="leg-s" style="color:'+l.c+'">'+l.s+'</span><span class="leg-d">'+l.d+'</span></div>';
    }
    document.getElementById("legend").innerHTML = lHTML;

    document.getElementById("form-view").style.display = "none";
    document.getElementById("results-view").style.display = "block";
    window.scrollTo({top:0, behavior:"smooth"});
  });

  // Back button
  document.getElementById("back-btn").addEventListener("click", function() {
    document.getElementById("results-view").style.display = "none";
    document.getElementById("form-view").style.display = "block";
    window.scrollTo({top:0, behavior:"smooth"});
  });

});
</script>

</body>
</html>
